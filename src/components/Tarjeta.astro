---
interface Props {
  title: string;
  subtitle: string;
  dataTarget: string;
  dataColor: string;
  hoverClasses: string;
  titleHoverClasses: string;
  extraClasses?: string;
}

const {
  title,
  subtitle,
  dataTarget,
  dataColor,
  hoverClasses,
  titleHoverClasses,
  extraClasses = ""
} = Astro.props;
---

<div
  class={`spec-item group bg-base-50 dark:bg-base-800/50 border border-base-200 dark:border-base-700 rounded-xl p-4 cursor-pointer ${hoverClasses} ${extraClasses}`.trim()}
  data-target={dataTarget}
  data-color={dataColor}
>
  <div class="flex justify-between items-center mb-1">
    <span class={`font-semibold text-base-900 dark:text-base-50 transition-colors ${titleHoverClasses}`}>{title}</span>
    <span class="text-xs bg-base-200 dark:bg-base-800 px-2 py-1 rounded text-base-600 dark:text-base-300">{subtitle}</span>
  </div>
  <div class="text-sm text-base-600 dark:text-base-400 leading-relaxed">
    <slot />
  </div>
</div>