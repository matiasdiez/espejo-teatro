---
interface Props {
  title: string;
  subtitle: string;
  dataTarget: string;
  dataColor: string;
  hoverClasses: string;
  titleHoverClasses: string;
  extraClasses?: string;
}

const {
  title,
  subtitle,
  dataTarget,
  dataColor,
  hoverClasses,
  titleHoverClasses,
  extraClasses = ""
} = Astro.props;
---

<div
  class={`spec-item group bg-calcareo-50 dark:bg-calcareo-800/50 border border-calcareo-200 dark:border-calcareo-700 rounded-xl p-4 cursor-pointer ${hoverClasses} ${extraClasses}`.trim()}
  data-target={dataTarget}
  data-color={dataColor}
>
  <div class="flex justify-between items-center mb-1">
    <span class={`font-semibold text-calcareo-900 dark:text-calcareo-50 transition-colors ${titleHoverClasses}`}>{title}</span>
    <span class="text-xs bg-calcareo-200 dark:bg-calcareo-800 px-2 py-1 rounded text-calcareo-600 dark:text-calcareo-300">{subtitle}</span>
  </div>
  <div class="text-sm text-calcareo-600 dark:text-calcareo-400 leading-relaxed">
    <slot />
  </div>
</div>