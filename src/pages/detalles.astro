---
import Layout from '@layouts/Layout.astro';
import projectData from '../../datos_espejo.json';
import materialsData from '../../datos_materiales.json';

const { project, elements } = projectData;

// Crear un diccionario de materiales para buscar rápidamente el nombre por ID
const materialMap = Object.fromEntries(
    materialsData.materials.map(m => [m.id, m])
);

// Agrupar las piezas del mueble por su tipo estructural
const structuralElements = elements.filter(e => ["Estructural", "Montaje"].includes(e.category));
const planarElements = elements.filter(e => ["Placa", "Superficie", "Electrónica"].includes(e.category));

// Función de ayuda para formatear dimensiones
const formatDim = (dim: any) => {
    if (!dim || (!dim.width && !dim.height && !dim.depth)) return '-';
    const w = dim.width ?? '(var)';
    const h = dim.height ?? '(var)';
    const d = dim.depth ?? '(var)';
    return `${w} x ${h} x ${d} mm`;
};
---

<Layout title={`Detalles - ${project.name}`} showPrintButton={true}>
    <main class="flex-1 max-w-5xl mx-auto w-full px-4 py-8 sm:px-6 lg:px-8 relative">
        <div class="absolute inset-0 pointer-events-none -z-10 print-hide" style="background-image: 
            linear-gradient(to right, var(--fallback-bc, oklch(var(--bc)/0.03)) 1px, transparent 1px),
            linear-grdient(to bottom, var(--fallback-bc, oklch(var(--bc)/0.03)) 1px, transparent 1px);
            background-size: 40px 40px;">
        </div>

        <div class="mb-10 text-center sm:text-left">
            <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight text-base-900 dark:text-base-50 flex items-center justify-center sm:justify-start gap-3">
                <i data-lucide="book-open" class="text-burgundy-500 w-8 h-8"></i>
                {project.name}
            </h1>
            <p class="mt-3 text-lg text-base-600 dark:text-base-400">
                Especificaciones constructivas, dimensiones totales y listado de piezas para mecanizado.
            </p>
        </div>

        <!-- Dimensiones Totales y Memoria -->
        <section class="card bg-base-100 dark:bg-base-900 shadow-xl border border-base-200 dark:border-base-800 mb-8">
            <div class="card-body p-6 sm:p-8">
                <h2 class="card-title text-xl font-bold mb-4 text-burgundy-600 dark:text-burgundy-400 flex gap-2 items-center">
                    <i data-lucide="box" class="w-5 h-5"></i>
                    Dimensiones Totales del Objeto
                </h2>
                <div class="flex flex-col sm:flex-row gap-4 mb-8">
                    <div class="bg-base-50 dark:bg-base-950 border border-base-200 dark:border-base-800 rounded-xl p-5 flex-1 shadow-inner">
                        <span class="block text-sm font-semibold uppercase tracking-wider text-base-500 dark:text-base-400 mb-1">Ancho Total</span>
                        <span class="text-3xl font-mono font-bold text-base-900 dark:text-base-100">{project.globalDimensions.width} {project.globalDimensions.unit}</span>
                    </div>
                    <div class="bg-base-50 dark:bg-base-950 border border-base-200 dark:border-base-800 rounded-xl p-5 flex-1 shadow-inner">
                        <span class="block text-sm font-semibold uppercase tracking-wider text-base-500 dark:text-base-400 mb-1">Alto Total</span>
                        <span class="text-3xl font-mono font-bold text-base-900 dark:text-base-100">{project.globalDimensions.height} {project.globalDimensions.unit}</span>
                    </div>
                    <div class="bg-base-50 dark:bg-base-950 border border-base-200 dark:border-base-800 rounded-xl p-5 flex-1 shadow-inner">
                        <span class="block text-sm font-semibold uppercase tracking-wider text-base-500 dark:text-base-400 mb-1">Profundidad Máx</span>
                        <span class="text-3xl font-mono font-bold text-base-900 dark:text-base-100">{project.globalDimensions.depth} {project.globalDimensions.unit}</span>
                    </div>
                </div>

                <h3 class="font-bold text-lg text-base-900 dark:text-base-100 mb-2">Memoria Descriptiva</h3>
                <div class="space-y-4">
                    {project.description?.map(paragraph => (
                        <p class="text-base-700 dark:text-base-300 leading-relaxed">{paragraph}</p>
                    ))}
                </div>
            </div>
        </section>

        <div class="flex flex-col gap-8 mb-8">
            <!-- Planilla Maderas -->
            <section class="card bg-base-100 dark:bg-base-900 shadow-xl border border-base-200 dark:border-base-800">
                <div class="card-body p-6">
                    <h2 class="card-title text-lg font-bold mb-4 text-base-900 dark:text-base-100 flex gap-2 items-center">
                        <i data-lucide="ruler" class="w-5 h-5 text-burgundy-500"></i>
                        Elementos Estructurales (Varillas y Marcos)
                    </h2>
                    <div class="overflow-x-auto w-full">
                        <table class="table table-zebra w-full text-base-800 dark:text-base-200">
                            <thead class="text-base-500 dark:text-base-400">
                                <tr>
                                    <th>Elemento</th>
                                    <th>Material / Sección</th>
                                    <th>Medidas Exteriores<br><span class="text-xs font-normal text-base-400">(ancho x alto x prof)</span></th>
                                    <th>Medidas Interiores<br><span class="text-xs font-normal text-base-400">(el agujero)</span></th>
                                </tr>
                            </thead>
                            <tbody>
                                {structuralElements.map(el => (
                                    <tr>
                                        <td class="font-medium align-top">{el.name}</td>
                                        <td class="align-top">{materialMap[el.materialId]?.name || el.materialId}</td>
                                        <td class="font-mono text-sm align-top">{formatDim(el.dimensions?.external)}</td>
                                        <td class="font-mono text-sm align-top">{formatDim(el.dimensions?.internal)}</td>
                                    </tr>
                                ))}
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>

            <!-- Planilla Placas -->
            <section class="card bg-base-100 dark:bg-base-900 shadow-xl border border-base-200 dark:border-base-800">
                <div class="card-body p-6">
                    <h2 class="card-title text-lg font-bold mb-4 text-base-900 dark:text-base-100 flex gap-2 items-center">
                        <i data-lucide="layers" class="w-5 h-5 text-burgundy-500"></i>
                        Elementos Planos (Núcleos y Superficies)
                    </h2>
                    <div class="overflow-x-auto w-full">
                        <table class="table table-zebra w-full text-base-800 dark:text-base-200">
                            <thead class="text-base-500 dark:text-base-400">
                                <tr>
                                    <th>Elemento</th>
                                    <th>Material</th>
                                    <th>Medidas<br><span class="text-xs font-normal text-base-400">(ancho x alto x prof)</span></th>
                                    <th>Detalles Extra</th>
                                </tr>
                            </thead>
                            <tbody>
                                {planarElements.map(el => (
                                    <tr>
                                        <td class="font-medium align-top">{el.name}</td>
                                        <td class="align-top">{materialMap[el.materialId]?.name || el.materialId}</td>
                                        <td class="font-mono text-sm align-top">{formatDim(el.dimensions?.external)}</td>
                                        <td class="text-sm align-top">{el.features && el.features[0] ? el.features[0] : '-'}</td>
                                    </tr>
                                ))}
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>
        </div>

        <!-- Notas Constructivas -->
        <section class="card bg-base-100 dark:bg-base-900 shadow-xl border border-base-200 dark:border-base-800 mb-12">
            <div class="card-body p-6 sm:p-8">
                <h2 class="card-title text-xl font-bold mb-4 text-base-900 dark:text-base-100 flex gap-2 items-center">
                    <i data-lucide="hammer" class="w-5 h-5 text-burgundy-500"></i>
                    Notas de Mecanizado
                </h2>
                <ul class="list-disc list-inside space-y-3 text-base-700 dark:text-base-300">
                    {elements.map(el => (
                        el.features && el.features.length > 0 && (
                            <li>
                                <strong class="text-base-900 dark:text-base-100">{el.name}:</strong> 
                                {el.features.join(" ")}
                            </li>
                        )
                    ))}
                </ul>
            </div>
        </section>
    </main>
</Layout>