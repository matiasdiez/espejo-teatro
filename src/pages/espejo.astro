---
// Restauración absoluta al momento "Perfecto"
import Layout from '@layouts/Layout.astro';
import Tarjeta from '@components/Tarjeta.astro';
import datosEspejo from '../../datos_espejo.json';

// Definimos un tipo estricto para la configuración de UI
type TarjetaConfig = {
  id?: string;
  isCustom?: boolean;
  title?: string;
  subtitle?: string;
  description?: string;
  dataTarget: string;
  dataColor: string;
  hoverClasses: string;
  titleHoverClasses: string;
  extraClasses?: string;
};

// Función para buscar un elemento en el JSON por su ID
const getElementData = (id: string) => datosEspejo.elements.find((e: any) => e.id === id) || ({} as any);

// Formatear la descripción o características
const formatDescription = (features: string[] | undefined) => {
  if (!features || features.length === 0) return "Sin descripción.";
  return features.join(" ");
};

// Mapeo de estilos y conexión con los IDs del JSON. 
// Agregamos tarjetas "isCustom" para las capas que no están directamente en el JSON como piezas físicas completas.
const tarjetasConfig: TarjetaConfig[] = [
  {
    id: "espejo_frontal",
    dataTarget: "layer-cristal",
    dataColor: "text-sky-500",
    hoverClasses: "hover:border-sky-400 hover:bg-sky-50 dark:hover:bg-sky-900/20",
    titleHoverClasses: "group-hover:text-sky-600 dark:group-hover:text-sky-400",
  },
  {
    isCustom: true,
    title: "Decapado",
    subtitle: "30mm ancho",
    description: "Franja translúcida en cara posterior. La luz de la ranura estanca sale frontalmente iluminando por retroproyección.",
    dataTarget: "layer-decapado",
    dataColor: "text-fuchsia-500",
    hoverClasses: "hover:border-fuchsia-400 hover:bg-fuchsia-50 dark:hover:bg-fuchsia-900/20",
    titleHoverClasses: "group-hover:text-fuchsia-600 dark:group-hover:text-fuchsia-400",
  },
  {
    id: "marco_principal",
    dataTarget: "layer-kiri",
    dataColor: "text-burgundy-600",
    hoverClasses: "hover:border-burgundy-600 hover:bg-burgundy-50 dark:hover:bg-burgundy-900/20",
    titleHoverClasses: "group-hover:text-burgundy-700 dark:group-hover:text-burgundy-500",
  },
  {
    id: "base_portante",
    dataTarget: "layer-mdf",
    dataColor: "text-burgundy-800",
    hoverClasses: "hover:border-burgundy-800 hover:bg-burgundy-100 dark:hover:bg-burgundy-900/40",
    titleHoverClasses: "group-hover:text-burgundy-900 dark:group-hover:text-burgundy-600",
  },
  {
    id: "reflector_trasero",
    dataTarget: "layer-mdf5",
    dataColor: "text-violet-500",
    hoverClasses: "hover:border-violet-400 hover:bg-violet-50 dark:hover:bg-violet-900/20",
    titleHoverClasses: "group-hover:text-violet-600 dark:group-hover:text-violet-400",
  },
  {
    id: "bastidor_pino",
    dataTarget: "layer-pino",
    dataColor: "text-yellow-400",
    hoverClasses: "hover:border-yellow-400 hover:bg-yellow-50 dark:hover:bg-yellow-900/20",
    titleHoverClasses: "group-hover:text-yellow-600 dark:group-hover:text-yellow-400",
  },
  {
    isCustom: true,
    title: "Electrónica 12V",
    subtitle: "Fuente Slim + COB",
    description: "Fuente embutida. Tira COB incrustada en el canto del MDF, disparando luz lateralmente hacia la ranura estanca.",
    dataTarget: "layer-led",
    dataColor: "text-yellow-300",
    hoverClasses: "hover:border-yellow-300 hover:bg-yellow-50 dark:hover:bg-yellow-900/30",
    titleHoverClasses: "group-hover:text-yellow-500 dark:group-hover:text-yellow-300",
    extraClasses: "shadow-[0_0_15px_rgba(253,224,71,0)] hover:shadow-[0_0_15px_rgba(253,224,71,0.4)]",
  },
  {
    id: "anclaje_cleat",
    dataTarget: "layer-cleat",
    dataColor: "text-stone-500",
    hoverClasses: "hover:border-stone-600 hover:bg-stone-100 dark:hover:bg-stone-800",
    titleHoverClasses: "group-hover:text-stone-700 dark:group-hover:text-stone-400",
  }
];

// Construimos el array final cruzando nuestra config de UI con los datos del JSON
const renderCards = tarjetasConfig.map(config => {
  if (config.isCustom) {
    return {
      ...config,
      title: config.title || "",
      subtitle: config.subtitle || "",
      description: config.description || "",
    };
  }
  
  const element = getElementData(config.id!);
  return {
    ...config,
    title: element.name || config.id,
    subtitle: element.dimensions && element.dimensions.external.width ? `${element.dimensions.external.width}x${element.dimensions.external.height}x${element.dimensions.external.depth}${element.dimensions.unit}` : "",
    description: formatDescription(element.features),
  };
});
---

<Layout title="Espejo - Machado Teatro">
  <style is:global>
      /* SVG Element Interactions */
      .svg-layer {
        transition:
          opacity 0.4s ease,
          filter 0.4s ease,
          stroke-width 0.4s ease;
      }
      .despiece-part {
        transition: opacity 0.2s ease-out;
      }

      .layer-highlight-mode .svg-layer:not(.highlighted) {
        opacity: 0.15 !important;
        filter: grayscale(100%) !important;
      }

      .layer-highlight-mode .svg-layer.highlighted.layer-decapado,
      .layer-highlight-mode .svg-layer.highlighted.layer-led {
        filter: brightness(1.3) drop-shadow(0 0 12px currentColor) !important;
      }

      .layer-highlight-mode
        .svg-layer.highlighted:not(.layer-decapado):not(.layer-led) {
        opacity: 1 !important;
        filter: brightness(1.3) drop-shadow(0 0 8px currentColor) !important;
        stroke: currentColor !important;
        stroke-width: 4px !important;
      }

      .spec-item {
        transition:
          transform 0.3s cubic-bezier(0.4, 0, 0.2, 1),
          background-color 0.2s;
        transform-origin: left center;
      }

      .spec-item:hover,
      .spec-item.active-hover {
        transform: scale(1.02);
      }

      .view-panel {
        display: none;
        opacity: 0;
        transition: opacity 0.4s ease, transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      }
      .view-panel.active {
        display: flex;
        opacity: 1;
      }
      @media (max-width: 639px) {
        .view-panel.card-active {
          transform: translateY(-85px);
        }
      }

      svg {
        max-width: 100%;
        height: auto;
      }

      /* Aceleración por Hardware para paneo y zoom */
      #zoom-container-corte, #zoom-container-frontal, #zoom-container-despiece {
        will-change: transform;
      }

      .dim-line {
        stroke: currentColor;
        opacity: 0.3;
        stroke-width: 1;
        stroke-dasharray: 4;
      }
      .dim-text-m {
        fill: currentColor;
        font-size: 6px;
      }

      .blueprint-mode {
        --bp-bg: #2563eb;
        --bp-line: #ffffff;
        --bp-grid: rgba(255, 255, 255, 0.08);
        --bp-fill: rgba(255, 255, 255, 0.1);
      }
      [data-theme="dark"] .blueprint-mode {
        --bp-bg: #0f172a;
        --bp-line: #bae6fd;
        --bp-grid: transparent;
        --bp-fill: rgba(186, 230, 253, 0.1);
      }
      .blueprint-mode #workspace-container {
        background-color: var(--bp-bg) !important;
        background-image: 
          linear-gradient(var(--bp-grid) 1px, transparent 1px),
          linear-gradient(90deg, var(--bp-grid) 1px, transparent 1px) !important;
        background-size: 40px 40px !important;
        background-position: center center !important;
      }
      .blueprint-mode .canvas-svg { filter: none !important; }
      .blueprint-mode .canvas-svg [stroke="currentColor"],
      .blueprint-mode .canvas-svg .dim-line { stroke: var(--bp-line) !important; opacity: 0.8 !important; }
      .blueprint-mode .canvas-svg text,
      .blueprint-mode .canvas-svg .dim-text-m,
      .blueprint-mode .canvas-svg .fill-current { fill: var(--bp-line) !important; color: var(--bp-line) !important; }
      .blueprint-mode .canvas-svg .layer-mdf, .blueprint-mode .canvas-svg .layer-kiri, .blueprint-mode .canvas-svg .layer-cleat,
      .blueprint-mode .canvas-svg .layer-pino, .blueprint-mode .canvas-svg .layer-mdf5, .blueprint-mode .canvas-svg polygon:not(.layer-decapado) {
        fill: url(#blueprintHatch) !important; stroke: var(--bp-line) !important; stroke-width: 0.5px !important;
      }
      .blueprint-mode .canvas-svg .svg-layer.svg-volume-side { fill: url(#blueprintHatchSide) !important; stroke: var(--bp-line) !important; stroke-width: 0.5px !important; }
      .blueprint-mode .canvas-svg .layer-cristal { fill: var(--bp-fill) !important; stroke: var(--bp-line) !important; stroke-width: 1px !important; }
      .blueprint-mode .canvas-svg .layer-decapado { fill: rgba(255, 255, 255, 0.3) !important; filter: none !important; stroke: var(--bp-line) !important; stroke-width: 0.5px !important; }
      .blueprint-mode .canvas-svg .layer-muro { fill: url(#concreteHatch) !important; stroke: var(--bp-line) !important; stroke-width: 0.5px !important; opacity: 0.7 !important; }
      .hide-dims .dim-line, .hide-dims .dim-text-m, .hide-dims g.dim-line, .hide-dims .dim-group { opacity: 0 !important; transition: opacity 0.3s ease; }
      .lights-off .layer-led, .lights-off [fill="url(#lightConeGrad)"] { opacity: 0 !important; transition: opacity 0.4s ease; }
      .lights-off .layer-decapado { filter: none !important; fill: rgba(255, 255, 255, 0.4) !important; }
      svg { transition: background-color 0.4s ease; }

      /* Bloquear scroll global para restaurar el formato de App estricta (igual al HTML original) */
      body {
        height: 100dvh !important;
        overflow: hidden !important;
      }
    </style>

    <div class="flex flex-col-reverse lg:flex-row w-full flex-1 overflow-hidden min-h-0">
      <!-- Sidebar with Specs -->
      <aside class="w-full lg:w-[380px] h-2/5 lg:h-full bg-calcareo-100 dark:bg-calcareo-900 border-t lg:border-t-0 lg:border-r border-calcareo-200 dark:border-calcareo-800 flex flex-col p-4 lg:p-6 gap-2 lg:gap-4 overflow-y-auto z-10 shadow-lg shrink-0 min-h-0" id="sidebar">
        <div class="flex justify-between items-center mb-2">
          <h2 class="text-xs font-bold uppercase tracking-widest text-calcareo-600 dark:text-calcareo-400">Desglose de Materiales</h2>
          <span class="text-xs text-calcareo-600 dark:text-calcareo-400">Pasa el ratón</span>
        </div>

        {renderCards.map((card) => (
          <Tarjeta
            title={card.title}
            subtitle={card.subtitle}
            dataTarget={card.dataTarget}
            dataColor={card.dataColor}
            hoverClasses={card.hoverClasses}
            titleHoverClasses={card.titleHoverClasses}
            extraClasses={card.extraClasses}
          >
            {card.description}
          </Tarjeta>
        ))}
      </aside>

      <!-- Main Content -->
      <main id="main-canvas" data-cards={JSON.stringify(renderCards)} class="flex-1 flex flex-col min-w-0 min-h-0 bg-calcareo-200 dark:bg-calcareo-950 relative overlay-pattern transition-colors duration-500">
        <div class="absolute inset-0 pointer-events-none -z-10" style="background-image: linear-gradient(to right, var(--fallback-bc, oklch(var(--bc) / 0.05)) 1px, transparent 1px), linear-gradient(to bottom, var(--fallback-bc, oklch(var(--bc) / 0.05)) 1px, transparent 1px); background-size: 40px 40px;"></div>

        <div class="flex flex-col sm:flex-row w-full bg-calcareo-100 dark:bg-calcareo-900 border-b border-calcareo-200 dark:border-calcareo-800 shadow-sm z-10">
          <!-- Select Responsive (Móvil) -->
          <div class="w-full px-4 pt-4 pb-3 sm:hidden">
            <select id="mobile-view-select" aria-label="Seleccionar vista de plano" class="select w-full font-medium bg-white dark:bg-calcareo-950 border-calcareo-200 dark:border-calcareo-700 shadow-sm">
              <option value="view-corte">Perfil (Corte Transversal)</option>
              <option value="view-frontal">Vista Frontal (Plan)</option>
              <option value="view-despiece">Explosión Isométrica</option>
            </select>
          </div>
          <!-- Tabs Originales (Desktop) -->
          <div class="tabs tabs-box flex-1 justify-start px-4 pt-4 rounded-none border-b-0 bg-transparent hidden sm:flex">
            <button class="tab tab-btn tab-active font-medium" data-view="view-corte">Perfil (Corte Transversal)</button>
            <button class="tab tab-btn font-medium" data-view="view-frontal">Vista Frontal (Plan)</button>
            <button class="tab tab-btn font-medium" data-view="view-despiece">Explosión Isométrica</button>
          </div>
          <div class="flex items-center justify-center gap-2 px-4 py-3 sm:py-0 border-t border-calcareo-200 dark:border-calcareo-800 sm:border-t-0 bg-calcareo-100 dark:bg-calcareo-900">
            <div class="hidden sm:flex items-center gap-1 border-r border-calcareo-200 dark:border-calcareo-800 pr-2 mr-1">
              <i data-lucide="zoom-out" class="w-4 h-4 text-base-content/70"></i>
              <input id="zoom-slider" aria-label="Nivel de zoom" type="range" min="0.5" max="3" step="0.1" value="1" class="range range-xs range-primary w-24" />
              <i data-lucide="zoom-in" class="w-4 h-4 text-base-content/70"></i>
              <button id="zoom-reset" class="p-1.5 rounded-full hover:bg-calcareo-200 dark:hover:bg-calcareo-800 transition-colors text-base-content ml-1" title="Reset Zoom">
                <i data-lucide="rotate-ccw" class="w-3.5 h-3.5"></i>
              </button>
            </div>
            <button id="btn-blueprint" class="p-2 rounded-lg hover:bg-calcareo-200 dark:hover:bg-calcareo-800 transition-colors" title="Modo Blueprint"><i data-lucide="drafting-compass" class="w-4 h-4 text-blue-600 dark:text-sky-500"></i></button>
            <button id="btn-lights" class="p-2 rounded-lg hover:bg-calcareo-200 dark:hover:bg-calcareo-800 transition-colors" title="Alternar Luces LED"><i id="icon-lights" data-lucide="lightbulb" class="w-4 h-4 text-amber-600 dark:text-yellow-500 fill-amber-600 dark:fill-yellow-500"></i></button>
            <button id="btn-dims" class="p-2 rounded-lg hover:bg-calcareo-200 dark:hover:bg-calcareo-800 transition-colors" title="Ocultar/Mostrar Cotas"><i id="icon-dims" data-lucide="ruler" class="w-4 h-4 text-base-content"></i></button>
          </div>
        </div>

        <svg width="0" height="0" class="absolute pointer-events-none">
          <defs>
            <linearGradient id="kiriGrad" x1="0%" y1="0%" x2="0%" y2="100%"><stop offset="0%" stop-color="#b45309" /><stop offset="50%" stop-color="#92400e" /><stop offset="100%" stop-color="#78350f" /></linearGradient>
            <linearGradient id="glassGrad" x1="0%" y1="0%" x2="0%" y2="100%"><stop offset="0%" stop-color="#bae6fd" /><stop offset="100%" stop-color="#0284c7" /></linearGradient>
            <linearGradient id="lightConeGrad" x1="0%" y1="100%" x2="0%" y2="0%"><stop offset="0%" stop-color="#fef08a" stop-opacity="0.5" /><stop offset="100%" stop-color="#fef08a" stop-opacity="0" /></linearGradient>
            <pattern id="blueprintHatch" patternUnits="userSpaceOnUse" width="10" height="10" patternTransform="rotate(45)"><line x1="0" y1="0" x2="0" y2="10" stroke="currentColor" stroke-width="2" /></pattern>
            <pattern id="blueprintHatchSide" patternUnits="userSpaceOnUse" width="10" height="10" patternTransform="rotate(-45)"><line x1="0" y1="0" x2="0" y2="10" stroke="currentColor" stroke-width="2" /></pattern>            
            <pattern id="concreteHatch" patternUnits="userSpaceOnUse" width="20" height="20">
              <path d="M 4,4 L 6,1 L 8,4 Z M 14,14 L 16,11 L 18,14 Z" stroke="currentColor" fill="none" stroke-width="0.5" />
              <circle cx="12" cy="4" r="0.5" fill="currentColor" /><circle cx="4" cy="14" r="0.5" fill="currentColor" /><circle cx="10" cy="10" r="0.5" fill="currentColor" />
            </pattern>
            <pattern id="mdfTex" patternUnits="userSpaceOnUse" width="10" height="10"><rect width="10" height="10" fill="#78350f" /><circle cx="2" cy="2" r="1" fill="#451a03" opacity="0.4" /></pattern>
            <filter id="glow" x="-50%" y="-50%" width="200%" height="200%"><feGaussianBlur stdDeviation="3" result="blur" /><feComposite in="SourceGraphic" in2="blur" operator="over" /></filter>
            <filter id="strongGlow" x="-50%" y="-50%" width="200%" height="200%"><feGaussianBlur stdDeviation="15" result="blur" /><feComposite in="SourceGraphic" in2="blur" operator="over" /></filter>
          </defs>
        </svg>

      <div id="workspace-container" class="flex-1 flex relative p-4 lg:p-12 z-0 w-full min-h-0 overflow-hidden items-center justify-center transition-colors duration-500">
          <!-- Tarjeta Flotante Interactiva (Móvil Fullscreen) -->
          <div id="mobile-card-overlay" class="absolute bottom-6 left-4 right-4 z-50 bg-calcareo-50/95 dark:bg-calcareo-900/95 backdrop-blur-xl border border-calcareo-200 dark:border-calcareo-700 rounded-2xl shadow-2xl p-5 flex flex-col gap-2 transition-all duration-300 opacity-0 pointer-events-none translate-y-4 sm:hidden">
            <div class="flex justify-between items-start gap-2">
              <div class="flex-1">
                <h3 id="mc-title" class="font-bold text-lg text-calcareo-900 dark:text-calcareo-50 leading-tight"></h3>
                <span id="mc-subtitle" class="text-xs font-mono font-semibold text-calcareo-500 uppercase tracking-wider"></span>
              </div>
              <button id="mc-close" class="p-1.5 -mr-2 -mt-2 rounded-full bg-calcareo-200/50 dark:bg-calcareo-800/50 hover:bg-calcareo-300 dark:hover:bg-calcareo-700 transition-colors text-base-content cursor-pointer" title="Cerrar">
                <i data-lucide="x" class="w-4 h-4"></i>
              </button>
            </div>
            <p id="mc-desc" class="text-sm text-calcareo-600 dark:text-calcareo-400 mt-1 leading-relaxed"></p>
          </div>

          <!-- Botón Fullscreen (Solo Móvil) -->
          <button id="btn-fullscreen" class="absolute top-4 right-4 z-50 p-2.5 bg-calcareo-100/90 dark:bg-calcareo-900/90 backdrop-blur-md border border-calcareo-200 dark:border-calcareo-800 rounded-xl shadow-lg sm:hidden hover:bg-calcareo-200 dark:hover:bg-calcareo-800 transition-colors text-base-content cursor-pointer" title="Pantalla Completa">
            <i id="icon-fullscreen" data-lucide="maximize" class="w-5 h-5"></i>
          </button>

          <!-- TAB 1: PERFIL (CORTE) -->
          <div id="view-corte" class="view-panel active text-calcareo-500 w-full h-full max-w-5xl zoom-area cursor-move active:cursor-grabbing">
            <div id="zoom-container-corte" class="w-full h-full" style="transform-origin: center center">
                <svg
                    viewBox="280 10 570 200"
                    xmlns="http://www.w3.org/2000/svg"
                    class="canvas-svg w-full h-full text-calcareo-500 dark:text-calcareo-400"
                    >
                    <rect
                        class="svg-layer layer-muro"
                        x="250"
                        y="150.5"
                        width="650"
                        height="40"
                        fill="currentColor"
                        opacity="0.1"
                    />
                    <text
                        x="350"
                        y="174"
                        class="dim-text-m text-calcareo-600 dark:text-calcareo-300"
                        font-size="10"
                        font-weight="600"
                        letter-spacing="0.2em"
                    >
                        MURO / PARED
                    </text>

                    <g
                        transform="translate(290, 170.5)"
                        stroke="currentColor"
                        opacity="0.5"
                        stroke-width="1.5"
                        fill="none"
                    >
                        <path d="M 0,0 L -20,0 M -10,10 L -20,0 L -10,-10" />
                        <text
                        x="-25"
                        y="3"
                        text-anchor="end"
                        font-size="8"
                        font-weight="600"
                        class="fill-current"
                        stroke="none"
                        >
                        ARRIBA (Techo)
                        </text>
                    </g>
                    <g
                        transform="translate(560, 170.5)"
                        stroke="currentColor"
                        opacity="0.5"
                        stroke-width="1.5"
                        fill="none"
                    >
                        <path d="M 0,0 L 20,0 M 10,10 L 20,0 L 10,-10" />
                        <text
                        x="25"
                        y="3"
                        text-anchor="start"
                        font-size="8"
                        font-weight="600"
                        class="fill-current"
                        stroke="none"
                        >
                        ABAJO (Piso)
                        </text>
                    </g>

                    <!-- Listón Francés: Amurado a Pared -->
                    <g class="svg-layer layer-cleat">
                        <polygon
                        points="372,120.5 450,120.5 450,150.5 402,150.5"
                        fill="#451a03"
                        />
                        <!-- Línea Guía: Pared -->
                        <polyline
                        points="425,135.5 445,170.5 480,170.5"
                        class="dim-line"
                        stroke-width="0.5"
                        stroke-dasharray="2,2"
                        fill="none"
                        />
                        <text
                        x="485"
                        y="172.5"
                        font-size="5"
                        fill="currentColor"
                        class="text-stone-500"
                        >
                        Amurado a la pared
                        </text>
                    </g>

                    <!-- Listón Francés: Atornillado MDF -->
                    <g class="svg-layer layer-cleat">
                        <polygon
                        points="320,119.5 368,119.5 398,149.5 320,149.5"
                        fill="#78350f"
                        />
                        <!-- Línea Guía: MDF -->
                        <polyline
                        points="335,134.5 355,198 480,198"
                        class="dim-line"
                        stroke-width="0.5"
                        stroke-dasharray="2,2"
                        fill="none"
                        />
                        <text
                        x="485"
                        y="200"
                        font-size="5"
                        fill="currentColor"
                        class="text-stone-500"
                        >
                        Atornillado a Base MDF
                        </text>
                    </g>

                    <!-- Base MDF -->
                    <rect
                        class="svg-layer layer-mdf"
                        x="300"
                        y="97"
                        width="420"
                        height="18"
                        fill="url(#mdfTex)"
                    />

                    <!-- Reflector MDF 5.5mm -->
                    <rect
                        class="svg-layer layer-mdf5"
                        x="250"
                        y="115"
                        width="519"
                        height="5.5"
                        fill="var(--c-mdf5)"
                        stroke="#64748b"
                        stroke-width="0.5"
                    />

                    <!-- Fuente Slim -->
                    <rect
                        class="svg-layer layer-led"
                        x="500"
                        y="97"
                        width="60"
                        height="18"
                        fill="currentColor"
                        opacity="0.2"
                        stroke="currentColor"
                        stroke-width="1"
                    />
                    <text
                        class="svg-layer layer-led dim-text-m"
                        x="530"
                        y="108"
                        text-anchor="middle"
                        font-size="4"
                    >
                        FUENTE
                    </text>

                    <!-- Cristal VASA -->
                    <rect
                        class="svg-layer layer-cristal"
                        x="300"
                        y="92"
                        width="450"
                        height="4"
                        fill="url(#glassGrad)"
                    />

                    <!-- Decapado -->
                    <rect
                        class="svg-layer layer-decapado"
                        x="720"
                        y="92"
                        width="30"
                        height="4"
                        fill="rgba(255,255,255,0.9)"
                        filter="url(#glow)"
                    />

                    <!-- LED COB -->
                    <rect
                        class="svg-layer layer-led"
                        x="720"
                        y="97"
                        width="3"
                        height="18"
                        fill="var(--c-led)"
                        filter="url(#glow)"
                    />

                    <!-- Bastidor de Pino -->
