    <script>
      // Importamos las funciones de lucide para recrear íconos cuando actualizamos el botón de cotas dinámicamente
      import { createIcons, icons } from 'lucide';

      document.addEventListener("DOMContentLoaded", () => {
        // --- ESTADO DE ZOOM & PAN (Subimos variables para evitar errores TDZ) ---
        let currentScale = 1;
        let currentX = 0;
        let currentY = 0;
        let isDragging = false;
        let startX = 0, startY = 0;
        let isUpdating = false;

        // --- LÓGICA DE TARJETA FLOTANTE (MÓVIL FULLSCREEN) ---
        const mainCanvas = document.getElementById("main-canvas");
        const cardsData = mainCanvas && mainCanvas.dataset.cards ? JSON.parse(mainCanvas.dataset.cards) : [];
        const mobileCardOverlay = document.getElementById("mobile-card-overlay");
        const mcTitle = document.getElementById("mc-title");
        const mcSubtitle = document.getElementById("mc-subtitle");
        const mcDesc = document.getElementById("mc-desc");
        const mcClose = document.getElementById("mc-close");

        function showMobileCard(targetClass: string) {
          // Solo mostrar si estamos en fullscreen y en pantalla móvil
          if (!document.fullscreenElement || window.innerWidth >= 640) return;
          const card = cardsData.find((c: any) => c.dataTarget === targetClass);
          if (!card || !mobileCardOverlay) return;

          if (mcTitle) {
            mcTitle.textContent = card.title;
            mcTitle.className = `font-bold text-lg leading-tight ${card.dataColor}`;
          }
          if (mcSubtitle) mcSubtitle.textContent = card.subtitle;
          if (mcDesc) mcDesc.textContent = card.description;

          mobileCardOverlay.classList.remove("opacity-0", "pointer-events-none", "translate-y-4");
          mobileCardOverlay.classList.add("opacity-100", "pointer-events-auto", "translate-y-0");

          const activeView = document.querySelector(".view-panel.active");
          if (activeView) activeView.classList.add("card-active");
        }

        function hideMobileCard() {
          if (!mobileCardOverlay) return;
          mobileCardOverlay.classList.add("opacity-0", "pointer-events-none", "translate-y-4");
          mobileCardOverlay.classList.remove("opacity-100", "pointer-events-auto", "translate-y-0");

          document.querySelectorAll(".view-panel").forEach(v => v.classList.remove("card-active"));
        }

        if (mcClose) mcClose.addEventListener("click", hideMobileCard);

        function updateTransform() {
          const containers = [
            document.getElementById("zoom-container-corte"),
            document.getElementById("zoom-container-frontal"),
            document.getElementById("zoom-container-despiece")
          ];
          containers.forEach(container => {
            if (container) {
              container.style.transition = isDragging ? "none" : "transform 0.1s ease-out";
              container.style.transform = `translate(${currentX}px, ${currentY}px) scale(${currentScale})`;
            }
          });
        }

        const zoomSlider = document.getElementById("zoom-slider") as HTMLInputElement | null;
        const zoomReset = document.getElementById("zoom-reset");
        const zoomAreas = document.querySelectorAll(".zoom-area");

        // --- TABS LOGIC ---
        const tabs = document.querySelectorAll(".tab-btn");
        const views = document.querySelectorAll(".view-panel");
        const mobileSelect = document.getElementById("mobile-view-select") as HTMLSelectElement | null;

        tabs.forEach((btn) => {
          btn.addEventListener("click", () => {
            tabs.forEach((t) => t.classList.remove("tab-active"));
            views.forEach((v) => v.classList.remove("active"));

            btn.classList.add("tab-active");
            const btnElement = btn as HTMLElement;
            if (btnElement.dataset.view) {
              const targetView = document.getElementById(btnElement.dataset.view);
              if (targetView) targetView.classList.add("active");

              if (mobileSelect) {
                mobileSelect.value = btnElement.dataset.view;
              }
            }

            // Reset zoom when switching tabs
            currentScale = 1;
            currentX = 0;
            currentY = 0;
            if (zoomSlider) {
              zoomSlider.value = "1";
            }
            hideMobileCard();
            updateTransform();
          });
        });

        // --- MOBILE SELECT LOGIC ---
        if (mobileSelect) {
          mobileSelect.addEventListener("change", (e) => {
            const target = e.target as HTMLSelectElement;
            const targetViewId = target.value;
            
            views.forEach((v) => v.classList.remove("active"));
            const targetView = document.getElementById(targetViewId);
            if (targetView) targetView.classList.add("active");

            tabs.forEach((t) => {
              const tElement = t as HTMLElement;
              if (tElement.dataset.view === targetViewId) {
                t.classList.add("tab-active");
              } else {
                t.classList.remove("tab-active");
              }
            });

            // Reset zoom when switching tabs
            currentScale = 1;
            currentX = 0;
            currentY = 0;
            if (zoomSlider) {
              zoomSlider.value = "1";
            }
            hideMobileCard();
            updateTransform();
          });
        }

        // --- FUNCIONES PARA OVERLAY DE MEDIDAS (VISTA FRONTAL) ---
        function showFrontalDimOverlay(specItem: HTMLElement) {
          const dimOverlay = document.getElementById("frontal-dim-overlay");
          if (!dimOverlay) return;
          const titleText = specItem.querySelector('.font-semibold')?.textContent || '';
          const spans = specItem.querySelectorAll('span');
          const dimText = spans.length > 1 ? spans[1].textContent || '' : '';
          
          const dimTitle = document.getElementById("frontal-dim-title");
          const dimValue = document.getElementById("frontal-dim-value");
          
          if (dimTitle && dimValue) {
              dimTitle.textContent = titleText;
              dimValue.textContent = dimText;
          }
          dimOverlay.classList.remove("opacity-0", "-translate-y-4");
          dimOverlay.classList.add("opacity-100", "translate-y-0");
        }

        function hideFrontalDimOverlay() {
          const dimOverlay = document.getElementById("frontal-dim-overlay");
          if (dimOverlay) {
              dimOverlay.classList.remove("opacity-100", "translate-y-0");
              dimOverlay.classList.add("opacity-0", "-translate-y-4");
          }
        }

        // --- HOVER (LAYERS) LOGIC ---
        const specItems = document.querySelectorAll(".spec-item") as NodeListOf<HTMLElement>;
        specItems.forEach((item) => {
          item.addEventListener("mouseenter", () => {
            const targetClass = item.dataset.target;
            const mainColorClass = item.dataset.color;
            document.body.classList.add("layer-highlight-mode");
            item.classList.add("active-hover");

            if (targetClass) {
              document.querySelectorAll("." + targetClass).forEach((el) => {
                el.classList.add("highlighted");
                if (mainColorClass) el.classList.add(mainColorClass);
              });
            }
            showFrontalDimOverlay(item);
          });

          item.addEventListener("mouseleave", () => {
            const targetClass = item.dataset.target;
            const mainColorClass = item.dataset.color;
            document.body.classList.remove("layer-highlight-mode");
            item.classList.remove("active-hover");

            if (targetClass) {
              document.querySelectorAll("." + targetClass).forEach((el) => {
                el.classList.remove("highlighted");
                if (mainColorClass) el.classList.remove(mainColorClass);
              });
            }
            hideFrontalDimOverlay();
          });
        });

        // --- TWO-WAY HOVER (SVG -> SIDEBAR) ---
        const svgLayers = document.querySelectorAll(".svg-layer");
        svgLayers.forEach((layer) => {
          // Click en móvil para la tarjeta flotante
          layer.addEventListener("click", (e) => {
            const classList = Array.from(layer.classList);
            const targetClass = classList.find((c) => c.startsWith("layer-"));
            if (targetClass) {
              showMobileCard(targetClass);
            }
            e.stopPropagation(); // Evitar que el click llegue al canvas y cierre la tarjeta
          });

          layer.addEventListener("mouseenter", () => {
            const classList = Array.from(layer.classList);
            const targetClass = classList.find((c) => c.startsWith("layer-"));
            if (targetClass) {
              const specItem = document.querySelector(`.spec-item[data-target="${targetClass}"]`) as HTMLElement | null;
              if (specItem) {
                const mainColorClass = specItem.dataset.color;
                document.body.classList.add("layer-highlight-mode");
                specItem.classList.add("active-hover");

                // Trigger hover classes
                if (!specItem.dataset.hoverClassesCached) {
                  const hClass: string[] = [];
                  Array.from(specItem.classList).forEach((c) => {
                    if (c.startsWith("hover:")) hClass.push(c.replace("hover:", ""));
                    if (c.startsWith("dark:hover:")) hClass.push(c.replace("dark:hover:", "dark:"));
                  });
                  specItem.dataset.hoverClasses = JSON.stringify(hClass);
                  const titleSpan = specItem.querySelector("span") as HTMLElement | null;
                  if (titleSpan) {
                    const tClass: string[] = [];
                    Array.from(titleSpan.classList).forEach((c) => {
                      if (c.startsWith("group-hover:")) tClass.push(c.replace("group-hover:", ""));
                      if (c.startsWith("dark:group-hover:")) tClass.push(c.replace("dark:group-hover:", "dark:"));
                    });
                    titleSpan.dataset.hoverClasses = JSON.stringify(tClass);
                  }
                  specItem.dataset.hoverClassesCached = "true";
                }
                const hoverClasses: string[] = JSON.parse(specItem.dataset.hoverClasses || "[]");
            specItem.classList.remove("bg-calcareo-50", "dark:bg-calcareo-800/50", "border-calcareo-200", "dark:border-calcareo-700");
                if (hoverClasses.length > 0) specItem.classList.add(...hoverClasses);

                const titleSpan = specItem.querySelector("span") as HTMLElement | null;
                if (titleSpan) {
                  const titleHover: string[] = JSON.parse(titleSpan.dataset.hoverClasses || "[]");
              titleSpan.classList.remove("text-calcareo-900", "dark:text-calcareo-50");
                  if (titleHover.length > 0) titleSpan.classList.add(...titleHover);
                }

                document.querySelectorAll("." + targetClass).forEach((el) => {
                  el.classList.add("highlighted");
                  if (mainColorClass) el.classList.add(mainColorClass);
                });
                specItem.scrollIntoView({ behavior: "smooth", block: "nearest" });
                showFrontalDimOverlay(specItem);
              }
            }
          });

          layer.addEventListener("mouseleave", () => {
            const classList = Array.from(layer.classList);
            const targetClass = classList.find((c) => c.startsWith("layer-"));
            if (targetClass) {
              const specItem = document.querySelector(`.spec-item[data-target="${targetClass}"]`) as HTMLElement | null;
              if (specItem) {
                const mainColorClass = specItem.dataset.color;
                document.body.classList.remove("layer-highlight-mode");
                specItem.classList.remove("active-hover");

                const hoverClasses: string[] = JSON.parse(specItem.dataset.hoverClasses || "[]");
                if (hoverClasses.length > 0) specItem.classList.remove(...hoverClasses);
            specItem.classList.add("bg-calcareo-50", "dark:bg-calcareo-800/50", "border-calcareo-200", "dark:border-calcareo-700");

                const titleSpan = specItem.querySelector("span") as HTMLElement | null;
                if (titleSpan) {
                  const titleHover: string[] = JSON.parse(titleSpan.dataset.hoverClasses || "[]");
                  if (titleHover.length > 0) titleSpan.classList.remove(...titleHover);
              titleSpan.classList.add("text-calcareo-900", "dark:text-calcareo-50");
                }

                document.querySelectorAll("." + targetClass).forEach((el) => {
                  el.classList.remove("highlighted");
                  if (mainColorClass) el.classList.remove(mainColorClass);
                });
                hideFrontalDimOverlay();
              }
            }
          });
        });

        // Cerrar tarjeta al hacer click en el fondo del canvas
        if (mainCanvas) {
          mainCanvas.addEventListener("click", (e) => {
            const target = e.target as HTMLElement;
            if (!target.closest(".svg-layer") && !target.closest("#mobile-card-overlay")) {
              hideMobileCard();
            }
          });
        }

        // --- TOOLBAR BUTTONS ---
        const btnBlueprint = document.getElementById("btn-blueprint");
        const btnLights = document.getElementById("btn-lights");
        const btnDims = document.getElementById("btn-dims");

        if (btnBlueprint && mainCanvas) {
          btnBlueprint.addEventListener("click", () => {
            mainCanvas.classList.toggle("blueprint-mode");
            btnBlueprint.classList.toggle("bg-blue-200");
            btnBlueprint.classList.toggle("dark:bg-sky-500/20");
          });
        }

        if (btnLights && mainCanvas) {
          btnLights.addEventListener("click", () => {
            mainCanvas.classList.toggle("lights-off");
            const icon = document.getElementById("icon-lights");
            if (icon) {
              if (mainCanvas.classList.contains("lights-off")) {
                icon.classList.remove("fill-amber-600", "text-amber-600", "dark:fill-yellow-500", "dark:text-yellow-500");
                icon.classList.add("text-base-content/40");
            btnLights.classList.add("bg-calcareo-200", "dark:bg-calcareo-800");
              } else {
                icon.classList.add("fill-amber-600", "text-amber-600", "dark:fill-yellow-500", "dark:text-yellow-500");
                icon.classList.remove("text-base-content/40");
            btnLights.classList.remove("bg-calcareo-200", "dark:bg-calcareo-800");
              }
            }
          });
        }

        if (btnDims && mainCanvas) {
          btnDims.addEventListener("click", () => {
            mainCanvas.classList.toggle("hide-dims");
            const icon = document.getElementById("icon-dims");
            if (icon) {
              if (mainCanvas.classList.contains("hide-dims")) {
                icon.setAttribute("data-lucide", "eye-off");
                icon.classList.remove("text-base-content");
                icon.classList.add("text-base-content/40");
            btnDims.classList.add("bg-calcareo-200", "dark:bg-calcareo-800");
              } else {
                icon.setAttribute("data-lucide", "ruler");
                icon.classList.add("text-base-content");
                icon.classList.remove("text-base-content/40");
            btnDims.classList.remove("bg-calcareo-200", "dark:bg-calcareo-800");
              }
              createIcons({ icons });
            }
          });
        }

        // --- FULLSCREEN LOGIC ---
        const btnFullscreen = document.getElementById("btn-fullscreen");
        const iconFullscreen = document.getElementById("icon-fullscreen");
        if (btnFullscreen && mainCanvas) {
          btnFullscreen.addEventListener("click", () => {
            if (!document.fullscreenElement) {
              mainCanvas.requestFullscreen().catch(err => console.warn(err));
            } else {
              document.exitFullscreen();
            }
          });
          document.addEventListener("fullscreenchange", () => {
            if (iconFullscreen) {
              iconFullscreen.setAttribute("data-lucide", document.fullscreenElement ? "minimize" : "maximize");
              createIcons({ icons });
            }
            
            // Forzar el recentrado del dibujo al cambiar de tamaño la pantalla
            currentScale = 1;
            currentX = 0;
            currentY = 0;
            if (zoomSlider) zoomSlider.value = "1";
            updateTransform();

            if (!document.fullscreenElement) {
              hideMobileCard();
            }
          });
        }

        // --- LOGICA DEL SLIDER DE ENSAMBLAJE (DESPIECE) ---
        const assembleSlider = document.getElementById("assemble-slider") as HTMLInputElement | null;
        const despieceParts = document.querySelectorAll(".despiece-part") as NodeListOf<HTMLElement | SVGElement>;
        const despieceGuides = document.querySelectorAll(".despiece-guide") as NodeListOf<HTMLElement | SVGElement>;
        const despieceTexts = document.querySelectorAll(".despiece-text") as NodeListOf<HTMLElement | SVGElement>;
        const kiriFrontPart = document.getElementById("kiri-front-part");
        const despieceResetBtn = document.getElementById("despiece-reset-btn");
        const kiriMainPart = document.querySelector('[data-is-kiri-main="true"]');
        const despiecePlayBtn = document.getElementById("despiece-play-btn");

        if (assembleSlider) {
          assembleSlider.addEventListener("input", (e) => {
            const target = e.target as HTMLInputElement;
            const progress = parseFloat(target.value) / 100;
            despieceParts.forEach(part => {
              const explodeY = parseFloat(part.getAttribute("data-explode-y") || "0");
              const assembleY = parseFloat(part.getAttribute("data-assemble-y") || "0");
              const currentY = assembleY + (explodeY - assembleY) * progress;
              part.setAttribute("transform", `translate(850, ${currentY})`);
              if (part.getAttribute("data-occluded") === "true") {
                part.style.opacity = Math.min(1, progress * 5).toString();
              }
            });
            if (kiriMainPart && kiriFrontPart) {
                const transformAttr = kiriMainPart.getAttribute('transform');
                if (transformAttr) kiriFrontPart.setAttribute('transform', transformAttr);
            }
            despieceGuides.forEach(guide => { guide.style.opacity = (progress * 0.3).toString(); });
            despieceTexts.forEach(txt => {
              txt.style.opacity = Math.min(1, progress * 2).toString();
            });
          });
        }

        if (despieceResetBtn && assembleSlider) {
          despieceResetBtn.addEventListener('click', () => {
              const duration = 600;
              const startSlider = parseFloat(assembleSlider.value);
              const startScale = currentScale;
              const startX = currentX;
              const startY = currentY;
              let startTime: number | null = null;
              function animateReset(timestamp: number) {
                  if (!startTime) startTime = timestamp;
                  const elapsed = timestamp - startTime;
                  const progress = Math.min(elapsed / duration, 1);
                  const easeProgress = 1 - Math.pow(1 - progress, 4);
                  if (assembleSlider) {
                    assembleSlider.value = (startSlider + (100 - startSlider) * easeProgress).toString();
                    assembleSlider.dispatchEvent(new Event('input', { bubbles:true }));
                  }
                  currentScale = startScale + (1 - startScale) * easeProgress;
                  currentX = startX + (0 - startX) * easeProgress;
                  currentY = startY + (0 - startY) * easeProgress;
                  if (zoomSlider) zoomSlider.value = currentScale.toString();
                  updateTransform();
                  if (progress < 1) requestAnimationFrame(animateReset);
              }
              requestAnimationFrame(animateReset);
          });
        }

        if (despiecePlayBtn && assembleSlider) {
          despiecePlayBtn.addEventListener('click', () => {
              const duration = 800;
              const startSlider = parseFloat(assembleSlider.value);
              let startTime: number | null = null;
              function animateAssemble(timestamp: number) {
                  if (!startTime) startTime = timestamp;
                  const elapsed = timestamp - startTime;
                  const progress = Math.min(elapsed / duration, 1);
                  const easeProgress = 1 - Math.pow(1 - progress, 3);
                  if (assembleSlider) {
                    assembleSlider.value = (startSlider + (0 - startSlider) * easeProgress).toString();
                    assembleSlider.dispatchEvent(new Event('input', { bubbles:true }));
                  }
                  if (progress < 1) requestAnimationFrame(animateAssemble);
              }
              requestAnimationFrame(animateAssemble);
          });
        }

        // --- ZOOM & PAN LOGIC BINDINGS ---
        if (zoomSlider) {
          zoomSlider.addEventListener("input", (e) => {
            const target = e.target as HTMLInputElement;
            currentScale = parseFloat(target.value);
            updateTransform();
          });

          if (zoomReset) {
            zoomReset.addEventListener("click", () => {
              currentScale = 1; currentX = 0; currentY = 0;
              zoomSlider.value = "1";
              updateTransform();
            });
          }

          zoomAreas.forEach(zoomArea => {
            zoomArea.addEventListener("mousedown", (e) => {
              const mouseEvent = e as MouseEvent;
              isDragging = true;
              startX = mouseEvent.clientX - currentX;
              startY = mouseEvent.clientY - currentY;
            });
            zoomArea.addEventListener("wheel", (e) => {
              const wheelEvent = e as WheelEvent;
              wheelEvent.preventDefault();
              const zoomStep = 0.1;
              if (wheelEvent.deltaY < 0) {
                currentScale = Math.min(parseFloat(zoomSlider.max), currentScale + zoomStep);
              } else {
                currentScale = Math.max(parseFloat(zoomSlider.min), currentScale - zoomStep);
              }
              zoomSlider.value = currentScale.toString();
              updateTransform();
            });
          });

          window.addEventListener("mousemove", (e) => {
            if (!isDragging) return;
            currentX = e.clientX - startX;
            currentY = e.clientY - startY;
            if (!isUpdating) {
              isUpdating = true;
              requestAnimationFrame(() => {
                updateTransform();
                isUpdating = false;
              });
            }
          });

          window.addEventListener("mouseup", () => {
            isDragging = false;
            updateTransform();
          });
        }
      });
    </script>
</Layout>